{
  "name": "vocl",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.{ts,vue,js,mjs,cjs,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,js,mjs,cjs,json,yml,yaml}\"",
    "lint": "pnpm --filter backend run lint && pnpm --filter frontend run lint",
    "lint:backend": "pnpm --filter backend run lint",
    "lint:frontend": "pnpm --filter frontend run lint",
    "test": "pnpm --filter backend run test",
    "typecheck": "pnpm --filter backend run typecheck && pnpm --filter frontend run typecheck",
    "build:frontend": "pnpm --filter frontend run build",
    "preview:frontend": "pnpm --filter frontend run preview",
    "dev:frontend": "pnpm --filter frontend run dev"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
